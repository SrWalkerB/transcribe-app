{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcribe App",
  "version": "0.1.8",
  "identifier": "com.srwalkerb.transcribe-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "transcribe-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/transcribe.py",
      "resources/install_ffmpeg.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzMTA5MjQyQ0RBNDZFNUEKUldSYWJxVE5RcElRa3cyTGNtTkpzRG9WRUhoaFo0WkNveHVsbnRlL2ZyNlBSb01nOGhlYUExWksK",
      "endpoints": [
        "https://github.com/SrWalkerB/Transcribe-APP/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}